

# ------------------------------------------------------------
# LLM Provider - OpenAI (REQUIRED if using OpenAI)
# Get your key at: https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here

# ------------------------------------------------------------
# LLM Provider - Google Gemini (REQUIRED if using Gemini)
# Get your key at: https://aistudio.google.com/app/apikey
# Both variables must be set to the same key value.
# GEMINI_API_KEY is used by the app logic to detect the provider.
# GOOGLE_GENERATIVE_AI_API_KEY is required by the @ai-sdk/google SDK.
# ------------------------------------------------------------
# GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------
# AI Model Configuration
# Default: gpt-4o-mini (cost-effective for most use cases)
# Options: gpt-4o, gpt-4o-mini, gemini-1.5-pro, gemini-1.5-flash
# ------------------------------------------------------------
AI_MODEL=gpt-4o-mini

# ------------------------------------------------------------
# Application Settings (Optional)
# ------------------------------------------------------------
# Base URL for the application (used for API calls in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Notification polling interval in milliseconds (default: 30000 = 30s)
NEXT_PUBLIC_NOTIFICATION_POLL_INTERVAL=30000
